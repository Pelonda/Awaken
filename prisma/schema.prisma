generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SiteMode {
  STANDARD
  KIOSK
}

enum SiteMemberRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  LOCKED
  MAINTENANCE
}

enum PinScope {
  USER
  BOOKING
  DEVICE
}

model Site {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  siteCode         String         @unique
  defaultMode      SiteMode       @default(STANDARD)
  isActive         Boolean        @default(true)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  members          SiteMember[]
  devices          Device[]
  pins             Pin[]
  sessions         Session[]
  bookings         Booking[]
  auditLogs        AuditLog[]
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  fullName         String?
  passwordHash     String?
  isActive         Boolean        @default(true)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  memberships      SiteMember[]
  pins             Pin[]
  sessions         Session[]
  bookings         Booking[]
  auditLogs        AuditLog[]     @relation("ActorLogs")
}

model SiteMember {
  id               String         @id @default(cuid())
  siteId           String
  userId           String
  role             SiteMemberRole @default(VIEWER)
  invitedEmail     String?
  invitationToken  String?
  acceptedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
}

model Device {
  id               String         @id @default(cuid())
  siteId           String
  name             String
  hostname         String
  enrollmentCode   String         @unique
  mode             SiteMode       @default(STANDARD)
  status           DeviceStatus   @default(OFFLINE)
  isRegistered     Boolean        @default(false)
  lastSeenAt       DateTime?
  clientVersion    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sessions         Session[]
  auditLogs        AuditLog[]

  @@unique([siteId, hostname])
}

model Pin {
  id               String         @id @default(cuid())
  siteId           String
  userId           String?
  deviceId         String?
  bookingId        String?
  scope            PinScope
  pinHash          String
  expiresAt        DateTime?
  isActive         Boolean        @default(true)
  version          Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([siteId, isActive])
}

model Booking {
  id               String         @id @default(cuid())
  siteId           String
  userId           String?
  source           String         @default("DIRECT") // DIRECT | SKEDDA
  externalRef      String?
  email            String
  name             String?
  status           String         @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  pinSentAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([siteId, email])
}

model Session {
  id               String         @id @default(cuid())
  siteId           String
  deviceId         String?
  userId           String?
  pinId            String?
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  status           String         @default("ACTIVE") // ACTIVE | ENDED | LOCKED
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  device           Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([siteId, status])
}

model AuditLog {
  id               String         @id @default(cuid())
  siteId           String?
  deviceId         String?
  actorId          String?
  action           String
  details          Json?
  ipAddress        String?
  createdAt        DateTime       @default(now())

  site             Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
  device           Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  actor            User?          @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([siteId, action])
}