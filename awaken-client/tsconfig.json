{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],

    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,

    "sourceMap": true,
    "baseUrl": ".",

    "moduleResolution": "node",
    "resolveJsonModule": true,

    "types": ["node", "electron"],

    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": ["src/**/*"]
}